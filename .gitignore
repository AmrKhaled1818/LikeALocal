# Secrets — real key files must never be committed
# app_config.dart, firebase_options.dart, and google-services.json now contain
# placeholder values and ARE tracked. Keep your real keys in a local-only copy
# (e.g. app_config.local.dart) or pass them via --dart-define at build time.
